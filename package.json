{
  "name": "last-version-ppt",
  "version": "1.0.0",
  "scripts": {
    "install:all": "bun install --cwd backend && bun install --cwd frontend",
    "dev": "bun run --parallel dev:server dev:client",
    "dev:server": "bun run --cwd backend dev",
    "dev:client": "bun run --cwd frontend dev",
    "start": "bun run --parallel start:server start:client",
    "start:server": "bun run --cwd backend start",
    "start:client": "bun run --cwd frontend build",
    "build:exe": "bun run scripts/build-exe.ts",
    "test:render": "bun run scripts/puppeteer-render-test.ts"
  },
  "devDependencies": {
    "puppeteer": "24.39.1"
  }
}
